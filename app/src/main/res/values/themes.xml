<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Applied after the splash screen dismisses. Dark windowBackground avoids the white flash. -->
    <style name="Theme.SCPReader" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/splash_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Cold-start splash (androidx core-splashscreen). -->
    <style name="Theme.SCPReader.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/splash_bg</item>
        <item name="postSplashScreenTheme">@style/Theme.SCPReader</item>
    </style>
</resources>
