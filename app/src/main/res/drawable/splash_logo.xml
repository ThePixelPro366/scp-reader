<?xml version="1.0" encoding="utf-8"?>
<!-- SCP containment mark (ring + three inward arrows), black on the white splash. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="120dp"
    android:height="120dp"
    android:viewportWidth="300"
    android:viewportHeight="300">

    <!-- outer ring -->
    <path
        android:strokeColor="#141316"
        android:strokeWidth="9"
        android:fillColor="#00000000"
        android:pathData="M93,150 A57,57 0 1 1 207,150 A57,57 0 1 1 93,150 Z" />

    <!-- three arrows at 0°, 120°, 240° -->
    <group android:pivotX="150" android:pivotY="150" android:rotation="0">
        <path android:fillColor="#141316" android:pathData="M150,145 L163,120 L154,120 L154,73 L146,73 L146,120 L137,120 Z" />
    </group>
    <group android:pivotX="150" android:pivotY="150" android:rotation="120">
        <path android:fillColor="#141316" android:pathData="M150,145 L163,120 L154,120 L154,73 L146,73 L146,120 L137,120 Z" />
    </group>
    <group android:pivotX="150" android:pivotY="150" android:rotation="240">
        <path android:fillColor="#141316" android:pathData="M150,145 L163,120 L154,120 L154,73 L146,73 L146,120 L137,120 Z" />
    </group>
</vector>
