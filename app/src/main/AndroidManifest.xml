<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- See installed browsers so "open original page" can target one (Android 11+ visibility). -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="https" />
        </intent>
    </queries>

    <application
        android:name=".ScpApp"
        android:allowBackup="true"
        android:usesCleartextTraffic="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="SCP Reader"
        android:supportsRtl="true"
        android:theme="@style/Theme.SCPReader.Starting">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="SCP Reader"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Open tapped SCP wiki article links inside the app. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="http" android:host="scp-wiki.wikidot.com" />
                <data android:scheme="https" android:host="scp-wiki.wikidot.com" />
                <data android:scheme="http" android:host="www.scp-wiki.wikidot.com" />
                <data android:scheme="https" android:host="www.scp-wiki.wikidot.com" />
                <data android:scheme="https" android:host="scpwiki.com" />
                <data android:scheme="https" android:host="www.scpwiki.com" />
                <data android:scheme="https" android:host="scp-wiki.net" />
            </intent-filter>
        </activity>
    </application>
</manifest>
